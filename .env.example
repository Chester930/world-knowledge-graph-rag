# ============================================================
# 智慧知識庫 v2 .env 設定範本
# 複製此檔案為 .env 並填入你的設定
# ============================================================

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password

# ── Provider 選擇 ─────────────────────────────────────────────
# LLM provider:       ollama | openai | anthropic | gemini | grok
# Embedding provider: local  | openai | ollama
LLM_PROVIDER=ollama
EMBEDDING_PROVIDER=local

# ── Ollama（本地，需先啟動 ollama serve）────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# ── 本地 Embedding（EMBEDDING_PROVIDER=local 時使用）────────────
LOCAL_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ── OpenAI ───────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ── Anthropic Claude ─────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Google Gemini ─────────────────────────────────────────────
GOOGLE_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ── xAI Grok ─────────────────────────────────────────────────
GROK_API_KEY=xai-...
GROK_MODEL=grok-2

# ── 資料路徑 ──────────────────────────────────────────────────
WORKSPACE_DIR=./workspace
CHUNK_STORE_DIR=./chunk_store

# ── 系統行為 ──────────────────────────────────────────────────
CONCEPT_EXTRACTION_MAX=8
SCORE_THRESHOLD=0.70

# ── 安全性 ────────────────────────────────────────────────────
API_KEY=
MAX_UPLOAD_SIZE_MB=50
